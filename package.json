{
  "name": "holidaywise",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && (timeout 120 prisma migrate deploy || echo '⚠ migrate deploy skipped after 120s (database unreachable?) — continuing; committed migrations apply on the next build once the DB is reachable') && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx prisma/seed.ts",
    "seed:admin": "tsx prisma/seed-admin.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.5.0",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "dotted-map": "^3.1.0",
    "google-auth-library": "^10.9.0",
    "imapflow": "^1.4.6",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.378.0",
    "mailparser": "^3.9.14",
    "next": "14.2.30",
    "nodemailer": "^9.0.1",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "tesseract.js": "^7.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.30",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
