generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// A staff note on a client, keyed by email so it ties together members and
// guests (enquiries/quotes are email-based, not account-linked).
model CustomerNote {
  id        String   @id @default(cuid())
  email     String
  body      String   @db.Text
  author    String?  // admin who wrote it
  createdAt DateTime @default(now())

  @@index([email])
}

// A follow-up task ("chase in 3 days"), attachable to a client email and/or an
// enquiry. Surfaces on a due-list with reminders.
model FollowUp {
  id        String    @id @default(cuid())
  email     String?
  enquiryId String?
  title     String
  dueAt     DateTime
  done      Boolean   @default(false)
  doneAt    DateTime?
  author    String?
  remindedAt DateTime?  // last time a reminder push was sent
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([done, dueAt])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  language  String?
  createdAt DateTime @default(now())
}

model SiteSetting {
  key   String @id
  value String @db.Text
}

model PageContent {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String   @db.Text
  author    String
  detail    String?  // e.g. "Bespoke journey to Japan" or a location
  image     String?
  rating    Int      @default(5)
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String?
  phone        String?
  createdAt    DateTime          @default(now())
  lastLoginAt  DateTime?
  shareToken   String?           @unique
  tier         String            @default("member") // member | silver | gold
  points       Int               @default(0)
  birthday     String?           // YYYY-MM-DD
  anniversary  String?           // YYYY-MM-DD
  occasionSentYear Int?          // last year an occasion email was sent (de-dupe)
  emailVerified   DateTime?      // set when the account's email is confirmed; null = pending
  verifyTokenHash String?        // HMAC of the current email-verification token
  verifyExpiresAt DateTime?      // expiry for the verification token
  resetTokenHash  String?        // HMAC of the current password-reset token
  resetExpiresAt  DateTime?      // expiry for the password-reset token
  referralCode     String?  @unique // this member's own share code
  referredById     String?           // the member who referred this account
  referralRewarded Boolean  @default(false) // whether the referrer has been credited
  sessions     CustomerSession[]
  bookings     Booking[]
  reviews      Review[]
  saved        SavedItem[]
  searches     SavedSearch[]
  itineraries  Itinerary[]
  credentials  WebauthnCredential[]
  travellers   Traveller[]
  notifications MemberNotification[]

  @@index([verifyTokenHash])
  @@index([resetTokenHash])
}

model InboundEmail {
  id         String   @id @default(cuid())
  messageId  String   @unique          // RFC Message-ID, for de-duplication
  uid        Int?                       // IMAP UID within the mailbox
  fromName   String?
  fromEmail  String
  toEmail    String?
  replyToEmail String?        // the message's Reply-To header, when present
  subject    String?
  bodyText   String?  @db.Text
  bodyHtml   String?  @db.Text
  receivedAt DateTime
  read       Boolean  @default(false)
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([receivedAt])
  @@index([read])
}

model RouteCache {
  key       String   @id           // "lat,lng->AIRPORT" (rounded origin)
  km        Int
  minutes   Int
  source    String   @default("precise") // precise | estimate (no road route)
  createdAt DateTime @default(now())
}

model SentEmail {
  id        String   @id @default(cuid())
  toEmail   String
  cc        String?
  bcc       String?
  fromEmail String
  subject   String
  bodyText  String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model MemberNotification {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title      String
  body       String   @db.Text
  url        String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model Traveller {
  id             String   @id @default(cuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fullName       String
  dob            String?  // YYYY-MM-DD as entered
  nationality    String?  // ISO-ish country code / name from the passport
  sex            String?  // M | F | X
  passportEnc    String?  // AES-256-GCM encrypted passport number (iv:tag:ciphertext)
  passportLast4  String?  // last 4 digits, stored plain for display only
  passportExpiry String?  // YYMMDD/date as entered
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId])
}

model Itinerary {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title      String
  notes      String?  @db.Text
  items      Json     // [{ type, id, title, image, href, price }]
  estimate   Int      @default(0)
  status     String   @default("draft") // draft | requested
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
}

model SavedSearch {
  id             String   @id @default(cuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type           String   // hotel | package | experience | cruise
  label          String
  href           String
  criteria       Json     // { city?, region?, category?, maxPrice? }
  createdAt      DateTime @default(now())
  lastNotifiedAt DateTime @default(now())

  @@index([customerId])
}

model Review {
  id         String    @id @default(cuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  authorName String
  type       String    // hotel | package | experience | cruise
  itemId     String
  rating     Int       // 1-5
  comment    String    @db.Text
  images     String[]  @default([])
  status     String    @default("pending") // pending | approved
  createdAt  DateTime  @default(now())

  @@index([type, itemId, status])
  @@index([status])
}

model SavedItem {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String   // hotel | package | experience | cruise
  itemId     String
  itemTitle  String
  image      String?
  href       String
  createdAt  DateTime @default(now())

  @@unique([customerId, type, itemId])
  @@index([customerId])
}

// A passkey (WebAuthn credential) registered by a member for passwordless login.
model WebauthnCredential {
  id           String   @id @default(cuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  credentialId String   @unique // base64url
  publicKey    String   // base64url of the COSE public key
  counter      Int      @default(0)
  transports   String?  // comma-joined transports
  deviceName   String?
  createdAt    DateTime @default(now())

  @@index([customerId])
}

model CustomerSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Booking {
  id          String    @id @default(cuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  type        String    // hotel | package | experience | cruise | flight | train
  itemId      String
  itemTitle   String
  image       String?
  guestName   String
  guestEmail  String
  guestPhone  String?
  checkIn     String?
  checkOut    String?
  guests      Int       @default(1)
  total       Int
  currency    String    @default("INR")
  status      String    @default("pending") // pending | confirmed | cancelled
  reference   String    @unique
  shareToken  String?   @unique // capability link to share this trip with a companion
  seat        String?   // flight bookings: seat chosen at booking (e.g. "14A")
  notes       String?   @db.Text
  documents   Json      @default("[]") // [{ label, url }] — vouchers, tickets, itineraries
  preTripSentAt  DateTime?
  postTripSentAt DateTime?
  pointsAwarded  Boolean   @default(false)
  flightStatus   String?   // last pushed live status: scheduled | airborne | landed | delayed
  flightStatusAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([customerId])
  @@index([status])
}

model Enquiry {
  id        String   @id @default(cuid())
  type      String   // "contact" | "booking"
  name      String
  email     String
  phone     String?
  subject   String?
  message   String?  @db.Text
  itemType  String?  // for bookings: hotel | package | experience | ...
  itemId    String?
  itemTitle String?
  total     Int?
  status    String   @default("new") // new | handled
  stage     String   @default("new") // pipeline: new | contacted | quoted | won | lost
  notes     String?  @db.Text
  followupSentAt DateTime?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([stage])
  @@index([createdAt])
}

model Newsletter {
  id             String    @id @default(cuid())
  subject        String
  previewText    String?
  html           String    @db.Text
  status         String    @default("draft") // draft | sent
  createdAt      DateTime  @default(now())
  sentAt         DateTime?
  recipientCount Int       @default(0)
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String?
  role         String         @default("staff") // owner | manager | staff | trainee (lib/admin/roles.ts)
  createdAt    DateTime       @default(now())
  lastLoginAt  DateTime?
  sessions     AdminSession[]
}

model AdminSession {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model Hotel {
  id            String   @id
  name          String
  location      String
  city          String
  country       String
  region        String
  stars         Int
  rating        Float
  reviewCount   Int
  pricePerNight Int
  image         String
  images        String[]
  category      String
  amenities     String[]
  highlights    String[]
  description   String   @db.Text
  badge         String?
  brand         String?
  lat           Float?
  lng           Float?
  officialSite  String?
  published     Boolean  @default(true)
  availableUnits Int?    // null = on request (no cap); otherwise bookable capacity
  priceOnRequest Boolean @default(false)
  faqs           Json?
  entryRequirements String? @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Flight {
  id              String   @id
  origin          String
  originCity      String
  destination     String
  destinationCity String
  airline         String
  airlineCode     String
  flightNumber    String
  departure       String
  arrival         String
  duration        String
  stops           Int
  price           Int
  businessPrice   Int?
  amenities       String[]
  currency        String   @default("INR")
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Train {
  id              String   @id
  name            String
  number          String
  origin          String
  originCity      String
  destination     String
  destinationCity String
  departure       String
  arrival         String
  duration        String
  classes         Json
  runsDays        String[]
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Experience {
  id          String   @id
  title       String
  location    String
  country     String
  duration    String
  price       Int
  category    String
  image       String
  description String   @db.Text
  includes    String[]
  badge       String?
  lat         Float?
  lng         Float?
  published   Boolean  @default(true)
  availableUnits Int?
  priceOnRequest Boolean @default(false)
  faqs        Json?
  entryRequirements String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Package {
  id             String   @id
  title          String
  subtitle       String
  destinations   String[]
  duration       String
  pricePerPerson Int
  image          String
  highlights     String[]
  includes       String[]
  category       String
  badge          String?
  published      Boolean  @default(true)
  featured       Boolean  @default(false)
  availableUnits Int?
  priceOnRequest Boolean  @default(false)
  faqs           Json?
  entryRequirements String? @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Cruise {
  id             String   @id
  name           String
  cruiseLine     String
  ship           String
  region         String
  departurePort  String
  ports          String[]
  duration       String
  pricePerPerson Int
  image          String
  category       String
  amenities      String[]
  highlights     String[]
  includes       String[]
  description    String   @db.Text
  rating         Float
  reviewCount    Int
  badge          String?
  published      Boolean  @default(true)
  availableUnits Int?
  priceOnRequest Boolean  @default(false)
  faqs           Json?
  entryRequirements String? @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PushSubscription {
  id         String   @id @default(cuid())
  endpoint   String   @unique
  p256dh     String
  auth       String
  customerId String?  // set when the subscriber is a signed-in member
  adminEmail String?  // set when the subscriber is an admin (new-mail alerts)
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([adminEmail])
}

model Offer {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  image       String
  badge       String?
  href        String?
  memberOnly  Boolean  @default(false)
  published   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model Moment {
  id        String   @id @default(cuid())
  image     String
  caption   String?
  handle    String?
  link      String?
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PressMention {
  id        String   @id @default(cuid())
  name      String
  image     String
  url       String?
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

model GiftCard {
  id             String   @id @default(cuid())
  code           String   @unique
  amount         Int
  balance        Int
  currency       String   @default("INR")
  recipientName  String?
  recipientEmail String?
  senderName     String?
  message        String?  @db.Text
  status         String   @default("active") // active | redeemed | void
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}

model Quote {
  id            String    @id @default(cuid())
  token         String    @unique
  customerName  String
  customerEmail String
  title         String
  lineItems     Json      // [{ label, amount }]
  total         Int
  currency      String    @default("INR")
  notes         String?   @db.Text
  validUntil    String?
  status        String    @default("draft") // draft | sent | accepted | declined
  respondedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

model BlogPost {
  slug      String   @id
  title     String
  category  String
  readTime  String
  date      String
  excerpt   String
  image     String
  author    String
  content   String[]
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeaturedDestination {
  id         String  @id @default(cuid())
  name       String
  tagline    String
  country    String
  image      String
  hotelCount Int
  sortOrder  Int     @default(0)
  published  Boolean @default(true)
}

// A record of admin actions — who changed what, for accountability.
model AuditLog {
  id        String   @id @default(cuid())
  userEmail String
  action    String   // create | update | delete | save
  entity    String   // e.g. "hotel", "booking", "settings", "page-content"
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Generic admin-managed content collections (team members, events, partner
// logos, homepage FAQ, …). Each entry's fields live in `data` (JSON), keyed by
// `type`, so new collections need no schema change — just a registry entry.
model Collection {
  id        String   @id @default(cuid())
  type      String   // e.g. "team" | "events" | "partners" | "homeFaq"
  data      Json     // the entry's fields, per the collection registry
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

// Fixed-window rate limiting for sensitive endpoints (login, password reset).
// Keyed by e.g. "login:ip:1.2.3.4" — count resets when resetAt passes.
model RateLimit {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime
}

// Simple key/count store for live site metrics (e.g. total visits).
model SiteStat {
  key   String @id
  count Int    @default(0)
}

// Per-day visit buckets for today / this-week / trend breakdowns.
model DailyVisit {
  day   String @id // YYYY-MM-DD
  count Int    @default(0)
}
