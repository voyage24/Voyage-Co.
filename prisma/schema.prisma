generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  language  String?
  createdAt DateTime @default(now())
}

model SiteSetting {
  key   String @id
  value String @db.Text
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String   @db.Text
  author    String
  detail    String?  // e.g. "Bespoke journey to Japan" or a location
  image     String?
  rating    Int      @default(5)
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String?
  phone        String?
  createdAt    DateTime          @default(now())
  lastLoginAt  DateTime?
  shareToken   String?           @unique
  tier         String            @default("member") // member | silver | gold
  sessions     CustomerSession[]
  bookings     Booking[]
  reviews      Review[]
  saved        SavedItem[]
  searches     SavedSearch[]
  itineraries  Itinerary[]
}

model Itinerary {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title      String
  notes      String?  @db.Text
  items      Json     // [{ type, id, title, image, href, price }]
  estimate   Int      @default(0)
  status     String   @default("draft") // draft | requested
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
}

model SavedSearch {
  id             String   @id @default(cuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type           String   // hotel | package | experience | cruise
  label          String
  href           String
  criteria       Json     // { city?, region?, category?, maxPrice? }
  createdAt      DateTime @default(now())
  lastNotifiedAt DateTime @default(now())

  @@index([customerId])
}

model Review {
  id         String    @id @default(cuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  authorName String
  type       String    // hotel | package | experience | cruise
  itemId     String
  rating     Int       // 1-5
  comment    String    @db.Text
  images     String[]  @default([])
  status     String    @default("pending") // pending | approved
  createdAt  DateTime  @default(now())

  @@index([type, itemId, status])
  @@index([status])
}

model SavedItem {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String   // hotel | package | experience | cruise
  itemId     String
  itemTitle  String
  image      String?
  href       String
  createdAt  DateTime @default(now())

  @@unique([customerId, type, itemId])
  @@index([customerId])
}

model CustomerSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Booking {
  id          String    @id @default(cuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  type        String    // hotel | package | experience | cruise | flight | train
  itemId      String
  itemTitle   String
  image       String?
  guestName   String
  guestEmail  String
  guestPhone  String?
  checkIn     String?
  checkOut    String?
  guests      Int       @default(1)
  total       Int
  currency    String    @default("INR")
  status      String    @default("pending") // pending | confirmed | cancelled
  reference   String    @unique
  notes       String?   @db.Text
  documents   Json      @default("[]") // [{ label, url }] — vouchers, tickets, itineraries
  preTripSentAt  DateTime?
  postTripSentAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([customerId])
  @@index([status])
}

model Enquiry {
  id        String   @id @default(cuid())
  type      String   // "contact" | "booking"
  name      String
  email     String
  phone     String?
  subject   String?
  message   String?  @db.Text
  itemType  String?  // for bookings: hotel | package | experience | ...
  itemId    String?
  itemTitle String?
  total     Int?
  status    String   @default("new") // new | handled
  stage     String   @default("new") // pipeline: new | contacted | quoted | won | lost
  notes     String?  @db.Text
  followupSentAt DateTime?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([stage])
  @@index([createdAt])
}

model Newsletter {
  id             String    @id @default(cuid())
  subject        String
  previewText    String?
  html           String    @db.Text
  status         String    @default("draft") // draft | sent
  createdAt      DateTime  @default(now())
  sentAt         DateTime?
  recipientCount Int       @default(0)
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String?
  createdAt    DateTime       @default(now())
  lastLoginAt  DateTime?
  sessions     AdminSession[]
}

model AdminSession {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model Hotel {
  id            String   @id
  name          String
  location      String
  city          String
  country       String
  region        String
  stars         Int
  rating        Float
  reviewCount   Int
  pricePerNight Int
  image         String
  images        String[]
  category      String
  amenities     String[]
  highlights    String[]
  description   String   @db.Text
  badge         String?
  brand         String?
  lat           Float?
  lng           Float?
  officialSite  String?
  published     Boolean  @default(true)
  availableUnits Int?    // null = on request (no cap); otherwise bookable capacity
  priceOnRequest Boolean @default(false)
  faqs           Json?
  entryRequirements String? @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Flight {
  id              String   @id
  origin          String
  originCity      String
  destination     String
  destinationCity String
  airline         String
  airlineCode     String
  flightNumber    String
  departure       String
  arrival         String
  duration        String
  stops           Int
  price           Int
  businessPrice   Int?
  amenities       String[]
  currency        String   @default("INR")
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Train {
  id              String   @id
  name            String
  number          String
  origin          String
  originCity      String
  destination     String
  destinationCity String
  departure       String
  arrival         String
  duration        String
  classes         Json
  runsDays        String[]
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Experience {
  id          String   @id
  title       String
  location    String
  country     String
  duration    String
  price       Int
  category    String
  image       String
  description String   @db.Text
  includes    String[]
  badge       String?
  lat         Float?
  lng         Float?
  published   Boolean  @default(true)
  availableUnits Int?
  priceOnRequest Boolean @default(false)
  faqs        Json?
  entryRequirements String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Package {
  id             String   @id
  title          String
  subtitle       String
  destinations   String[]
  duration       String
  pricePerPerson Int
  image          String
  highlights     String[]
  includes       String[]
  category       String
  badge          String?
  published      Boolean  @default(true)
  featured       Boolean  @default(false)
  availableUnits Int?
  priceOnRequest Boolean  @default(false)
  faqs           Json?
  entryRequirements String? @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Cruise {
  id             String   @id
  name           String
  cruiseLine     String
  ship           String
  region         String
  departurePort  String
  ports          String[]
  duration       String
  pricePerPerson Int
  image          String
  category       String
  amenities      String[]
  highlights     String[]
  includes       String[]
  description    String   @db.Text
  rating         Float
  reviewCount    Int
  badge          String?
  published      Boolean  @default(true)
  availableUnits Int?
  priceOnRequest Boolean  @default(false)
  faqs           Json?
  entryRequirements String? @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model GiftCard {
  id             String   @id @default(cuid())
  code           String   @unique
  amount         Int
  balance        Int
  currency       String   @default("INR")
  recipientName  String?
  recipientEmail String?
  senderName     String?
  message        String?  @db.Text
  status         String   @default("active") // active | redeemed | void
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}

model Quote {
  id            String    @id @default(cuid())
  token         String    @unique
  customerName  String
  customerEmail String
  title         String
  lineItems     Json      // [{ label, amount }]
  total         Int
  currency      String    @default("INR")
  notes         String?   @db.Text
  validUntil    String?
  status        String    @default("draft") // draft | sent | accepted | declined
  respondedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

model BlogPost {
  slug      String   @id
  title     String
  category  String
  readTime  String
  date      String
  excerpt   String
  image     String
  author    String
  content   String[]
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeaturedDestination {
  id         String  @id @default(cuid())
  name       String
  tagline    String
  country    String
  image      String
  hotelCount Int
  sortOrder  Int     @default(0)
  published  Boolean @default(true)
}
